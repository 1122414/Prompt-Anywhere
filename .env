# Prompt Anywhere 环境变量配置
# 优先级：环境变量 > config.yaml > 代码默认值

# ==================== 应用基础配置 ====================
APP_NAME=Prompt Anywhere
APP_VERSION=0.1.0
APP_AUTHOR=Prompt Anywhere Team
APP_ENV=local

# ==================== 窗口配置 ====================
DEFAULT_WINDOW_WIDTH=900
DEFAULT_WINDOW_HEIGHT=600
ALWAYS_ON_TOP=true
START_MINIMIZED=false
DEFAULT_WINDOW_OPACITY=1.0
MIN_WINDOW_OPACITY=0.60
MAX_WINDOW_OPACITY=1.00

# ==================== 快捷键配置 ====================
GLOBAL_HOTKEY=ctrl+alt+p
QUICK_MODE_HOTKEY=ctrl+alt+p
DEFAULT_MAIN_HOTKEY=ctrl+alt+m

# ==================== 存储配置 ====================
DATA_DIR=./data
EXPORT_DIR=./exports
USER_STATE_PATH=./app_state.json
APP_CONFIG_PATH=./app_config.json
FILE_ENCODING=utf-8

# ==================== UI 配置 ====================
DEFAULT_VIEW_MODE=edit
PYGMENTS_STYLE=github-dark

# ==================== 搜索配置（v0.2.0 Prompt Spotlight） ====================
SEARCH_ENABLE_PINYIN=true
SEARCH_ENABLE_INITIALS=true
SEARCH_ENABLE_FUZZY=true
SEARCH_FUZZY_THRESHOLD=60
SEARCH_FUZZY_MODE=balanced
SEARCH_FIRST_PAINT_RESULTS=30
SEARCH_DEBOUNCE_MS=120
SEARCH_MAX_RESULTS=100
SEARCH_SNIPPET_RADIUS=40
SEARCH_HIGHLIGHT_ENABLED=true
SEARCH_SELECTED_BG_COLOR=#e3f2fd
SEARCH_CASE_INSENSITIVE=true

# ==================== 复制与Esc配置 ====================
COPY_AUTO_HIDE=true
COPY_HIDE_DELAY_MS=200
ESC_HIDE_ENABLED=true

# ==================== 文件类型配置 ====================
SUPPORTED_PROMPT_EXTENSIONS=.md,.txt
IMAGE_ASSETS_DIR_NAME=_assets
PASTED_IMAGE_FORMAT=png

# ==================== 调试与日志配置 ====================
MAX_RECENT_FILES=10
DEFAULT_LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_MAX_FILE_SIZE_MB=10
LOG_BACKUP_COUNT=5
ENABLE_FILE_WATCHER=true

# ==================== 模板变量配置 ====================
TEMPLATE_VARIABLE_PATTERN=\{\{\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*\}\}
TEMPLATE_VARIABLE_MAX_COUNT=50
TEMPLATE_DEFAULT_MULTILINE=true

# ==================== Composer 配置 ====================
COMPOSER_SEPARATOR=\n\n---\n\n
COMPOSER_INCLUDE_FILE_TITLE=true
COMPOSER_TITLE_LEVEL=1
COMPOSER_AUTO_DETECT_VARIABLES=true
COMPOSER_SAVE_DIR=./data/组合模板
COMPOSER_EXPORT_DIR=./exports

# ==================== UI 按钮显示配置 ====================
SHOW_TEMPLATE_BUTTON=true
SHOW_COMPOSER_BUTTON=true
COMPOSER_WINDOW_WIDTH=900
COMPOSER_WINDOW_HEIGHT=600
TEMPLATE_DIALOG_WIDTH=700
TEMPLATE_DIALOG_HEIGHT=520

# ==================== 内置模板配置 ====================
BUILTIN_TEMPLATE_DIR=./builtin_templates
ENABLE_BUILTIN_TEMPLATES=true

# ==================== 备份与历史版本配置 ====================
DEFAULT_BACKUP_DIR=./backups
AUTO_BACKUP_ENABLED=true
AUTO_BACKUP_INTERVAL_HOURS=24
MAX_BACKUP_COUNT=20
HISTORY_ENABLED=true
MAX_VERSIONS_PER_FILE=20

# ==================== 开机自启配置 ====================
CLOSE_TO_TRAY=true

# ==================== 语义搜索配置（v0.3.0） ====================
SEMANTIC_SEARCH_ENABLED=false
SEMANTIC_SEARCH_PROVIDER=api
SEMANTIC_SEARCH_LOCAL_MODEL=BAAI/bge-small-zh-v1.5
SEMANTIC_SEARCH_API_BASE_URL=
SEMANTIC_SEARCH_API_KEY=
SEMANTIC_SEARCH_API_MODEL=text-embedding-3-small
SEMANTIC_SEARCH_TOP_K=20
SEMANTIC_SEARCH_MIN_SCORE=0.35
SEMANTIC_SEARCH_INDEX_ON_STARTUP=false
SEMANTIC_SEARCH_AUTO_REINDEX=true

# ==================== 知识库配置（v0.3.0） ====================
KNOWLEDGE_BASE_DIR=./.prompt_anywhere
KNOWLEDGE_BASE_AUTO_SYNC=true

# ==================== AI模板助手配置（v0.4.0） ====================
AI_TEMPLATE_ENABLED=false
AI_TEMPLATE_PROVIDER=openai_compatible
AI_TEMPLATE_BASE_URL=
AI_TEMPLATE_API_KEY=
AI_TEMPLATE_MODEL=
AI_TEMPLATE_TEMPERATURE=0.2
AI_TEMPLATE_TIMEOUT_SECONDS=30
AI_TEMPLATE_DETECTION_MODE=hybrid

# ==================== 模型配置（预留，供后续扩展） ====================
MODEL_PROVIDER=
MODEL_NAME=
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TEMPERATURE=0.7
