# Prompt Anywhere 环境变量配置
# 优先级：环境变量 > config.yaml > 代码默认值

# ==================== 应用基础配置 ====================
APP_NAME=Prompt Anywhere
APP_VERSION=0.1.0
APP_AUTHOR=Prompt Anywhere Team

# ==================== 窗口配置 ====================
# 默认窗口位置和大小
WINDOW_WIDTH=900
WINDOW_HEIGHT=600
WINDOW_X=100
WINDOW_Y=100

# 窗口行为
ALWAYS_ON_TOP=true
START_MINIMIZED=false

# ==================== 快捷键配置 ====================
# 全局快捷键，格式：ctrl+alt+p
# 支持的修饰键：ctrl, alt, shift, cmd(仅限Mac)
GLOBAL_HOTKEY=ctrl+alt+p

# ==================== 存储配置 ====================
# 数据目录（相对于应用根目录或绝对路径）
DATA_DIR=./data
EXPORT_DIR=./exports

# 文件编码
FILE_ENCODING=utf-8

# ==================== UI 配置 ====================
# 默认编辑模式：edit / preview
DEFAULT_MODE=edit

# ==================== Markdown 渲染配置 ====================
# 代码高亮主题
PYGMENTS_STYLE=github-dark

# ==================== 搜索配置 ====================
# 搜索是否忽略大小写
SEARCH_CASE_INSENSITIVE=true

# ==================== 调试配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 模型配置（预留，供后续扩展） ====================
MODEL_PROVIDER=
MODEL_NAME=
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_TEMPERATURE=0.7

# ==================== 调试配置 ====================
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用文件系统监控（自动刷新）
ENABLE_FILE_WATCHER=true
